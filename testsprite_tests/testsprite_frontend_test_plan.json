[
  {
    "id": "TC001",
    "title": "Crear una nueva actividad KANBAN con datos válidos (PMO)",
    "description": "Verifica que un usuario con rol PMO puede crear una actividad y verla en la lista.",
    "category": "Crear Actividad (KANBAN)",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the username/email field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click on the \"Iniciar sesión\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/dashboard\""
      },
      {
        "type": "action",
        "description": "Click on the navigation link/menu item for \"Actividades\" (POI) to open the activity list"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/poi/actividad/lista"
      },
      {
        "type": "action",
        "description": "Click on the \"Nueva Actividad\" button"
      }
    ]
  },
